# ═══ Chaeul Web (Vercel) — Environment Variables ═══
# Set semua ini di: Vercel Dashboard → Project → Settings → Environment Variables

# ── Storage: Upstash Redis (WAJIB agar data persist) ──
# Buat database gratis di https://console.upstash.com (Redis) → tab "REST API"
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AxxxTOKENxxx

# ── Token internal ──
ADMIN_TOKEN=ganti-token-admin-rahasia
SYNC_TOKEN=ganti-token-sync-rahasia

# ── Kredensial API bot (downloader/AI) — RAHASIA · StarNova API ──
# Disimpan HANYA di web. Bot mengambilnya saat start bila lisensi aktif.
# Jika seseorang menghapus sistem lisensi di script bot, bot tak menerima ini
# → downloader & AI mati total. JANGAN taruh di config.js bot.
#
# BOT_API_KEY = OWNER KEY StarNova (limit TAK TERBATAS).
# Buat key-nya: di repo starnova-dashboard jalankan → npm run owner-key
BOT_API_BASEURL=https://dash.starnova.my.id
BOT_API_KEY=snv_xxxxxxxxxxxxxxxxxxxxxxxxx

# ── Payment (opsional) ──
# Kosongkan = mode placeholder (konfirmasi manual via WA).
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
# MIDTRANS_PRODUCTION=false
# XENDIT_SECRET_KEY=xnd_development_xxxx
# XENDIT_CALLBACK_TOKEN=xxxx
# PAYMENT_MODE=placeholder
# PUBLIC_URL=https://your-app.vercel.app
